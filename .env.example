# Google Sheets service account credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private key from the downloaded JSON. Keep the \n escape sequences as-is.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
GOOGLE_SHEET_ID=your-google-sheet-id

# Any long random string, used to sign login session cookies
SESSION_SECRET=change-this-to-a-long-random-string
